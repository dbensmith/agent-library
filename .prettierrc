{
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "none",
  "printWidth": 120,
  "overrides": [
    {
      "files": ["**/.vscode/*.json"],
      "options": {
        "parser": "jsonc"
      }
    },
    {
      "files": "**/*.md",
      "options": {
        "printWidth": 400
      }
    }
  ]
}
